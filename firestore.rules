rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Users Collection
    // Doc ID = Auth UID. Role-scoped at sign-up; names required on update.
    match /users/{userId} {
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.role in ["student", "volunteer_org"];
      allow read: if isAuthenticated();
      allow update: if isOwner(userId)
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string;
      allow delete: if isOwner(userId);
    }

    // 2. Schools Collection — public read, auth write (MVP)
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // 3. Volunteer Orgs Collection
    // Public read; only creator can update/delete.
    match /volunteer_orgs/{orgId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && resource.data.createdBy == request.auth.uid;
    }

    // 4. Opportunities Collection
    // Public read; only the org that owns it (orgId == uid) can modify.
    match /opportunities/{opportunityId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && resource.data.orgId == request.auth.uid;
    }

    // 5. Opportunity Enrollment Collection (legacy — MVP simplification)
    match /opportunity_enrollment/{enrollmentId} {
      allow read: if isAuthenticated();
    }

    // 6. Student Hours Collection
    match /student_hours/{hoursId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.studentId == request.auth.uid;
    }

    // 7. Student Profiles Collection
    // Owners can fully manage their profile.
    // Any authenticated user can update hoursCompleted/badges — needed so
    // orgs can call updateApplicationStatus() to mark a volunteer hour complete.
    match /student_profiles/{userId} {
      allow read: if isAuthenticated();
      allow create, delete: if isOwner(userId);
      allow update: if isOwner(userId) || isAuthenticated();
    }

    // 8. Volunteer Org Profiles Collection
    // Public read so orgs are discoverable.
    // Only the linked user (uid == doc ID) can update/delete their own profile.
    match /volunteer_org_profiles/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isOwner(userId);
    }

    // 9. User Applications Collection
    // Doc ID: {userId}_{opportunityId}
    // Students create their own applications.
    // Any authenticated user can read (orgs need to see applicants).
    // Any authenticated user can update status (orgs approve/deny/complete).
    // No deletes — preserve audit trail.
    match /user_applications/{applicationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated();
    }

    // 10. User Saved Opportunities Collection
    // Doc ID: {userId}_{opportunityId}
    // Users manage only their own saved docs.
    match /user_saved_opportunities/{savedId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // 11. Reports Collection — immutable audit trail
    // Only authenticated users can create; no reads/updates/deletes.
    // reporterId must match the caller's UID to prevent spoofing.
    // Text is capped at 1-1000 chars to prevent abuse.
    match /reports/{reportId} {
      allow create: if isAuthenticated()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.reporterId is string
        && request.resource.data.opportunityId is string
        && request.resource.data.orgId is string
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 1000;
      allow read, update, delete: if false;
    }
  }
}

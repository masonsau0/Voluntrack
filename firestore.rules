rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to read and write their own applications
    match /user_applications/{applicationId} {
      allow read, write: if request.auth != null && (
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid)
      );
    }
    
    // Allow authenticated users to read and write their own saved opportunities
    match /user_saved_opportunities/{saveId} {
      allow read, write: if request.auth != null && (
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid)
      );
    }
    
    // Allow all authenticated users to read opportunities
    match /opportunities/{opportunityId} {
      allow read: if request.auth != null;
      allow write: if false; // Only admin via backend/script should write
    }
  }
}
